# Copy to .env and adjust. Loaded by run-local.sh.

# JDBC URL for the local Postgres container (see run-local.sh for the docker command).
# Host port 5433 avoids clashing with a system Postgres on 5432.
DATABASE_URL=jdbc:postgresql://localhost:5433/breviare
DB_USER=breviare
DB_PASSWORD=breviare

# HS256 signing key. MUST be >= 32 bytes or the app fails to start.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=replace-me-with-at-least-32-bytes-of-random-hex-0123456789abcdef

# Optional overrides (defaults shown).
PORT=8080
BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
